// RUN: sed 's/__IMPL__/egg/' %s > %t && MIM_PLUGIN_PATH=%S %mim %t -o -
// RUN: sed 's/__IMPL__/slotted/' %s > %t && MIM_PLUGIN_PATH=%S %mim %t -o -

plugin core;
plugin eqsat;
import pipeline;

fun extern _impl(): %eqsat.Impl =
    return %eqsat.__IMPL__;

lam is_even(i: Nat): Bool = (is_odd (%core.nat.sub (i, 1)), tt)#(%core.ncmp.e (i, 0))
and
lam is_odd (i: Nat): Bool = (is_even(%core.nat.sub (i, 1)), ff)#(%core.ncmp.e (i, 0));

fun extern f(): Bool = return (is_even 4);
